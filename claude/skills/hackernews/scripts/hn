#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["httpx"]
# ///
"""
Hacker News API fetcher.

Usage:
    hn stories [--type top|new|best|ask|show|job] [--limit N]
    hn item <id> [--with-comments] [--comment-depth N]
    hn user <username>
    hn updates

Output: Markdown (default) or JSON (--json).
"""

import argparse
import asyncio
import json
import re
import sys
from datetime import datetime, timezone
from html import unescape

import httpx

BASE = "https://hacker-news.firebaseio.com/v0"
HN_ITEM_LINK = "https://news.ycombinator.com/item?id={}"  # for markdown links only, no fetching

STORY_ENDPOINTS = {
    "top": "topstories",
    "new": "newstories",
    "best": "beststories",
    "ask": "askstories",
    "show": "showstories",
    "job": "jobstories",
}


# --- networking ---


async def fetch_json(client: httpx.AsyncClient, url: str):
    resp = await client.get(url, timeout=15)
    resp.raise_for_status()
    return resp.json()


async def fetch_item(client: httpx.AsyncClient, item_id: int) -> dict | None:
    try:
        return await fetch_json(client, f"{BASE}/item/{item_id}.json")
    except Exception:
        return None


async def fetch_items_batch(client: httpx.AsyncClient, ids: list[int]) -> list[dict]:
    tasks = [fetch_item(client, i) for i in ids]
    results = await asyncio.gather(*tasks)
    return [r for r in results if r is not None]


async def fetch_comments_tree(
    client: httpx.AsyncClient, item: dict, max_depth: int, current_depth: int = 0
) -> dict:
    result = {k: v for k, v in item.items()}
    kids = item.get("kids", [])
    if not kids or current_depth >= max_depth:
        result.pop("kids", None)
        if kids:
            result["kids_count"] = len(kids)
        return result

    child_items = await fetch_items_batch(client, kids)
    children = []
    for child in child_items:
        if child.get("deleted") or child.get("dead"):
            continue
        subtree = await fetch_comments_tree(client, child, max_depth, current_depth + 1)
        children.append(subtree)
    result["children"] = children
    result.pop("kids", None)
    return result


# --- formatting helpers ---


def fmt_time(unix_ts: int | None) -> str | None:
    if unix_ts is None:
        return None
    return datetime.fromtimestamp(unix_ts, tz=timezone.utc).strftime("%Y-%m-%d %H:%M UTC")


def strip_html(html: str | None) -> str:
    if not html:
        return ""
    text = html.replace("<p>", "\n\n").replace("<br>", "\n").replace("<br/>", "\n")
    text = re.sub(r'<a\s+href="([^"]*)"[^>]*>([^<]*)</a>', r"[\2](\1)", text)
    text = re.sub(r"<[^>]+>", "", text)
    return unescape(text).strip()


def summarize_story(item: dict) -> dict:
    return {
        "id": item.get("id"),
        "title": item.get("title"),
        "url": item.get("url"),
        "score": item.get("score"),
        "by": item.get("by"),
        "time": fmt_time(item.get("time")),
        "descendants": item.get("descendants", 0),
        "type": item.get("type"),
    }


# --- markdown renderers ---


def _plural(n: int, singular: str, plural: str | None = None) -> str:
    if n == 1:
        return f"{n} {singular}"
    return f"{n} {plural or singular + 's'}"


def md_stories(stories: list[dict], story_type: str) -> str:
    lines = [f"# HN {story_type.title()} Stories\n"]
    for i, s in enumerate(stories, 1):
        title = s["title"] or "(no title)"
        url = s["url"]
        hn_link = HN_ITEM_LINK.format(s["id"])
        score = s["score"] or 0
        comments = s["descendants"] or 0
        by = s["by"] or "?"
        time = s["time"] or "?"

        if url:
            title_part = f"[{title}]({url})"
        else:
            title_part = f"[{title}]({hn_link})"
        lines.append(f"{i}. {title_part}")
        lines.append(f"   {score} points by {by} | {time} | "
                      f"[{_plural(comments, 'comment')}]({hn_link})")
    return "\n".join(lines)


def md_item(item: dict) -> str:
    lines = []
    title = item.get("title")
    item_type = item.get("type", "item")
    url = item.get("url")
    hn_link = HN_ITEM_LINK.format(item["id"])

    # header
    if title:
        lines.append(f"# {title}")
    else:
        lines.append(f"# {item_type.title()} {item['id']}")

    # metadata line
    meta = []
    if item.get("score") is not None:
        meta.append(f"{item['score']} points")
    if item.get("by"):
        meta.append(f"by {item['by']}")
    if item.get("time"):
        meta.append(fmt_time(item["time"]))
    if meta:
        lines.append(" | ".join(meta))

    # links
    link_parts = [f"[HN discussion]({hn_link})"]
    if url:
        link_parts.insert(0, f"[link]({url})")
    lines.append(" | ".join(link_parts))
    lines.append("")

    # body text
    text = strip_html(item.get("text"))
    if text:
        lines.append(text)
        lines.append("")

    # comments
    children = item.get("children")
    if children:
        lines.append(f"## Comments ({len(children)} top-level)\n")
        for child in children:
            lines.append(_md_comment(child, depth=0))

    kids_count = item.get("kids_count")
    if kids_count and not children:
        lines.append(f"*{_plural(kids_count, 'comment')} (use --with-comments to fetch)*")

    return "\n".join(lines)


def _md_comment(comment: dict, depth: int) -> str:
    indent = "  " * depth
    by = comment.get("by", "?")
    time = fmt_time(comment.get("time")) or ""
    text = strip_html(comment.get("text"))
    # wrap text lines with indent
    wrapped = ("\n" + indent + "> ").join(text.split("\n"))

    lines = [f"{indent}> {by} ({time}):"]
    lines.append(f"{indent}> {wrapped}")

    kids_count = comment.get("kids_count")
    if kids_count:
        lines.append(f"{indent}> *[{_plural(kids_count, 'reply', 'replies')} hidden]*")
    lines.append("")

    for child in comment.get("children", []):
        lines.append(_md_comment(child, depth + 1))

    return "\n".join(lines)


def md_user(user: dict) -> str:
    lines = [f"# User: {user['id']}\n"]
    lines.append(f"- **Karma:** {user.get('karma', 0)}")
    lines.append(f"- **Created:** {fmt_time(user.get('created'))}")
    lines.append(f"- **Submissions:** {user.get('submitted_count', '?')} total")

    about = strip_html(user.get("about"))
    if about:
        lines.append(f"\n## About\n\n{about}")

    submitted = user.get("submitted", [])
    if submitted:
        lines.append(f"\n## Recent Submissions (latest {len(submitted)} IDs)\n")
        lines.append(", ".join(str(s) for s in submitted))

    return "\n".join(lines)


def md_updates(updates: dict) -> str:
    items = updates.get("items", [])
    profiles = updates.get("profiles", [])
    lines = ["# HN Recent Updates\n"]
    lines.append(f"## Changed Items ({len(items)})\n")
    lines.append(", ".join(str(i) for i in items[:30]))
    if len(items) > 30:
        lines.append(f"\n*...and {len(items) - 30} more*")
    lines.append(f"\n## Changed Profiles ({len(profiles)})\n")
    lines.append(", ".join(profiles[:30]))
    if len(profiles) > 30:
        lines.append(f"\n*...and {len(profiles) - 30} more*")
    return "\n".join(lines)


# --- commands ---


def output(data, md_text: str, use_json: bool):
    if use_json:
        print(json.dumps(data, indent=2, ensure_ascii=False))
    else:
        print(md_text)


async def cmd_stories(args):
    endpoint = STORY_ENDPOINTS[args.type]
    async with httpx.AsyncClient() as client:
        ids = await fetch_json(client, f"{BASE}/{endpoint}.json")
        ids = ids[: args.limit]
        items = await fetch_items_batch(client, ids)
        stories = [summarize_story(it) for it in items]
    output(stories, md_stories(stories, args.type), args.json)


async def cmd_item(args):
    async with httpx.AsyncClient() as client:
        item = await fetch_item(client, args.id)
        if item is None:
            print(f"Error: Item {args.id} not found", file=sys.stderr)
            sys.exit(1)
        if args.with_comments:
            item = await fetch_comments_tree(client, item, args.comment_depth)
        else:
            kids = item.get("kids", [])
            item.pop("kids", None)
            if kids:
                item["kids_count"] = len(kids)
        item["time_iso"] = fmt_time(item.get("time"))
    output(item, md_item(item), args.json)


async def cmd_user(args):
    async with httpx.AsyncClient() as client:
        user = await fetch_json(client, f"{BASE}/user/{args.username}.json")
        if user is None:
            print(f"Error: User {args.username} not found", file=sys.stderr)
            sys.exit(1)
        user["created_iso"] = fmt_time(user.get("created"))
        submitted = user.get("submitted", [])
        user["submitted_count"] = len(submitted)
        user["submitted"] = submitted[:20]
    output(user, md_user(user), args.json)


async def cmd_updates(args):
    async with httpx.AsyncClient() as client:
        updates = await fetch_json(client, f"{BASE}/updates.json")
    output(updates, md_updates(updates), args.json)


def main():
    parser = argparse.ArgumentParser(description="Fetch Hacker News data")
    parser.add_argument("--json", action="store_true", help="Output JSON instead of markdown")
    sub = parser.add_subparsers(dest="command", required=True)

    # stories
    p_stories = sub.add_parser("stories", help="Fetch story lists")
    p_stories.add_argument(
        "--type",
        choices=list(STORY_ENDPOINTS.keys()),
        default="top",
        help="Story list type (default: top)",
    )
    p_stories.add_argument(
        "--limit", type=int, default=10, help="Number of stories (default: 10)"
    )

    # item
    p_item = sub.add_parser("item", help="Fetch a single item")
    p_item.add_argument("id", type=int, help="Item ID")
    p_item.add_argument(
        "--with-comments", action="store_true", help="Include comment tree"
    )
    p_item.add_argument(
        "--comment-depth", type=int, default=2, help="Max comment depth (default: 2)"
    )

    # user
    p_user = sub.add_parser("user", help="Fetch user profile")
    p_user.add_argument("username", help="HN username")

    # updates
    sub.add_parser("updates", help="Fetch recently changed items and profiles")

    args = parser.parse_args()

    coro = {
        "stories": cmd_stories,
        "item": cmd_item,
        "user": cmd_user,
        "updates": cmd_updates,
    }[args.command](args)

    asyncio.run(coro)


if __name__ == "__main__":
    main()
