{
  "debug": false,
  "agent": {
    "websearch": { "endpoint": "https://test.8421044.xyz:8443", "key_file": "~/.config/sift/client.key" },
    "user_agent_name": "claude-cli/2.1.190 (external, cli)",
    "ui": {
      "invertDiffColors": true,
      "statusline": {
        "command": "~/.config/llms/statusline.sh",
        "updateIntervalMs": 300
      }
    },
    "permissions": {
      "allow": [],
      "deny": [
        "Read(./.env)",
        "Read(./keys.json)"
      ],
      "ask": []
    },
    "model": "ds-flash",
    "background_model": "ds-flash",
    "compact_model": "inherit",
    "subagent_model": "ds",
    "micro_compact": {
      "enabled": false,
      "keep_recent_turns": 6,
      "threshold": 80
    },
    "permission_mode": "yolo",
    "session": {
      "cleanup_period_days": 9999
    },
    "persistent_debug": {
      "enabled": true,
      "cleanup_period_days": 1
    },
    "hooks": {
      "PreToolUse": [],
      "PostToolUse": []
    },
    "auto_compact": {
      "enabled": true,
      "threshold": 94
    },
    "bash": {
      "defaultTimeoutMs": 60000,
      "sandbox": {
        "mode": "auto_allow",
        "additional_allowed_write_paths": [
          "~/.local",
          "~/projects/gopath",
          "~/.osay",
          "~/.config",
          "~/.yaw/",
          "~/Library/Application Support/obsidian/",
          "~/.cache",
          "~/Library/Caches/",
          "/Users/tizee/Library/Caches",
          "~/.cargo"
        ]
      }
    },
    "verify_completion": false,
    "verification_model": "inherit"
  }
}
