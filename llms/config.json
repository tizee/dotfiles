{
  "debug": false,
  "agent": {
    "ui": {
      "statusline": {
        "command": "~/.config/llms/statusline.sh",
        "updateIntervalMs": 300
      }
    },
    "permissions": {
      "allow": [],
      "deny": [
        "Read(./.env)",
        "Read(./keys.json)"
      ],
      "ask": []
    },
    "model": "minimax",
    "background_model": "gpt",
    "compact_model": "gpt-5.4-mini",
    "subagent_model": "minimax",
    "micro_compact": {
      "enabled": false,
      "keep_recent_turns": 6,
      "threshold": 80
    },
    "permission_mode": "yolo",
    "session": {
      "cleanup_period_days": 14
    },
    "persistent_debug": {
      "enabled": true,
      "cleanup_period_days": 1
    },
    "hooks": {
      "PreToolUse": [],
      "PostToolUse": []
    },
    "auto_compact": {
      "enabled": true,
      "threshold": 90
    },
    "bash": {
      "defaultTimeoutMs": 60000,
      "sandbox": {
        "mode": "auto_allow",
        "additional_allowed_write_paths": [
          "~/.osay",
          "~/.config/llm/",
          "~/.yaw/",
          "~/Library/Application Support/obsidian/",
          "~/.local/share/uv/tools/",
          "~/Library/Caches/org.swift.swiftpm/",
          "~/.config/llm/rss-reader.opml"
        ]
      }
    }
  }
}
