{
  "debug": false,
  "agent": {
    "model": "glm",
    "ui": {
      "statusline": {
        "command": "~/.config/llms/statusline.sh",
        "updateIntervalMs": 300
      }
    },
    "permissions": {
      "allow": [],
      "deny": [
        "Read(./.env)",
        "Read(./keys.json)"
      ],
      "ask": []
    },
    "image_model": "kimi-for-coding-instant",
    "background_model": "glm-4.5-air",
    "compact_model": "kimi-for-coding",
    "subagent_model": "minimax",
    "micro_compact": {
      "enabled": false,
      "keep_recent_turns": 6,
      "threshold": 80
    },
    "session": {
      "cleanup_period_days": 14
    },
    "persistent_debug": {
      "enabled": true,
      "cleanup_period_days": 1
    },
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "*",
          "hooks": [{"command": "python3 ~/projects/project-AI/tools/llm.tizee/examples/hooks/log_tool_use.py"}]
        }
      ],
      "PostToolUse": [
        {
          "matcher": "*",
          "hooks": [{"command": "python3 ~/projects/project-AI/tools/llm.tizee/examples/hooks/log_tool_result.py"}]
        }
      ]
    },
    "bash": {
      "defaultTimeoutMs": 60000,
      "sandbox": {
        "mode": "regular",
        "additional_allowed_write_paths": [
          "~/.osay",
          "~/.config/llm/"
        ]
      }
    }
  }
}
